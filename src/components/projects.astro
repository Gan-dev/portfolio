---
import { Image } from "astro:assets";
import phonetec from "../../public/phonetec.png";
import sumaq from "../../public/sumaq.jpg";
import umbralAi from "../../public/umbralAi.jpg";
import paulaNails from "../../public/paulaNails.png";
import heladeriaRoma from "../../public/heladeriaroma.webp";

interface Tech {
  name: string;
  icon: string;
}

interface Project {
  title: string;
  description: string;
  image: ImageMetadata;
  link: string;
  preview: string;
  status: "Deployed" | "On Development";
  technologies: Tech[];
  deployment: string;
}

const projects: Project[] = [
  {
    title: "UMBRAL.AI",
    description: "AI-powered platform for intelligent decision-making and automation workflows with machine learning integration.",
    image: umbralAi as ImageMetadata,
    link: "https://github.com/Gan-dev",
    preview: "",
    status: "On Development",
    technologies: [
      { name: "Python",     icon: "/svg/Python.svg" },
      { name: "Node.js",    icon: "/svg/nodejs.svg" },
      { name: "PostgreSQL", icon: "/svg/postgresql.svg" },
      { name: "Docker",     icon: "/svg/docker.svg" },
      { name: "AI Agent",   icon: "/svg/ai-agent.svg" },
    ],
    deployment: "Remote Server",
  },
  {
    title: "Sumaq.es",
    description: "Modern e-commerce platform with advanced inventory management and real-time analytics for retail business.",
    image: sumaq as ImageMetadata,
    link: "https://github.com/Gan-dev",
    preview: "",
    status: "On Development",
    technologies: [
      { name: "Astro",        icon: "/svg/astro.svg" },
      { name: "React",        icon: "/svg/react.svg" },
      { name: "Tailwind CSS", icon: "/svg/tailwindcss.svg" },
      { name: "Node.js",      icon: "/svg/nodejs.svg" },
      { name: "MongoDB",      icon: "/svg/MongoDB.svg" },
    ],
    deployment: "Remote Server",
  },
  {
    title: "Phonetec.es",
    description: "Professional tech repair services website with online booking system and customer management dashboard.",
    image: phonetec as ImageMetadata,
    link: "https://github.com/Gan-dev",
    preview: "https://phonetec-v2.vercel.app/",
    status: "Deployed",
    technologies: [
      { name: "Astro",        icon: "/svg/astro.svg" },
      { name: "React",        icon: "/svg/react.svg" },
      { name: "TypeScript",   icon: "/svg/typeScript.svg" },
      { name: "Tailwind CSS", icon: "/svg/tailwindcss.svg" },
    ],
    deployment: "Vercel",
  },
  {
    title: "PaulaNails.es",
    description: "Beauty salon booking platform with appointment scheduling, service catalog, and client portfolio management.",
    image: paulaNails as ImageMetadata,
    link: "https://paulanails-es.vercel.app",
    preview: "https://paulanails-es.vercel.app",
    status: "Deployed",
    technologies: [
      { name: "Astro",        icon: "/svg/astro.svg" },
      { name: "React",        icon: "/svg/react.svg" },
      { name: "TypeScript",   icon: "/svg/typeScript.svg" },
      { name: "Tailwind CSS", icon: "/svg/tailwindcss.svg" },
    ],
    deployment: "Vercel",
  },
  {
    title: "HeladeriaRoma.com",
    description: "Ice cream shop website with an interactive menu, online ordering system, and location-based store finder.",
    image: heladeriaRoma as ImageMetadata,
    link: "https://github.com/Gan-dev",
    preview: "https://heladeriaroma.com",
    status: "Deployed",
    technologies: [
      { name: "React",        icon: "/svg/react.svg" },
      { name: "Deno",         icon: "/svg/deno.svg" },
      { name: "Tailwind CSS", icon: "/svg/tailwindcss.svg" },
    ],
    deployment: "Vercel",
  },
];

const deploymentIcons: Record<string, string> = {
  "Vercel":        "/svg/vercel.svg",
  "Remote Server": "/svg/nodejs.svg",
};
---

<section
  id="projects"
  class="py-16 text-[var(--white)]"
>
  <div class="max-w-5xl mx-auto">
    <div class="mb-10">
      <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">My work</h2>
      <h3 class="text-4xl md:text-5xl font-bold mb-3">Projects</h3>
      <div class="h-1 w-20 bg-gradient-to-r from-[var(--sec)] to-transparent rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project) => (
          <div class="group relative">
            {/* Glow border on hover */}
            <div class="absolute -inset-px rounded-2xl bg-gradient-to-br from-[var(--sec)]/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500" />

            <div class="relative h-full flex flex-col bg-[var(--component-bg)] rounded-2xl border border-[var(--white-icon-tr)] group-hover:border-[var(--sec)]/25 transition-all duration-400 overflow-hidden">

              {/* Image */}
              <a
                href={project.preview || project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="block relative overflow-hidden flex-shrink-0"
              >
                <Image
                  src={project.image}
                  alt={project.title}
                  class="w-full h-44 object-cover group-hover:scale-105 transition-transform duration-700 brightness-90 group-hover:brightness-100"
                />
                {/* Gradient overlay on image */}
                <div class="absolute inset-0 bg-gradient-to-t from-[var(--component-bg)] via-transparent to-transparent opacity-60" />

                {/* Status badge */}
                <div class="absolute top-3 left-3">
                  <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 text-xs font-semibold rounded-full backdrop-blur-sm ${project.status === "Deployed" ? "bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" : "bg-amber-500/20 text-amber-400 border border-amber-500/30"}`}>
                    <span class={`w-1.5 h-1.5 rounded-full ${project.status === "Deployed" ? "bg-emerald-400" : "bg-amber-400"} animate-pulse`} />
                    {project.status}
                  </span>
                </div>

                {/* Deployment badge */}
                <div class="absolute top-3 right-3">
                  <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-[var(--component-bg)]/80 border border-[var(--white-icon-tr)] backdrop-blur-sm">
                    <img
                      src={deploymentIcons[project.deployment]}
                      alt={project.deployment}
                      class="w-3.5 h-3.5 object-contain opacity-80 invert"
                    />
                    <span class="text-[10px] font-medium text-[var(--white-icon)]">{project.deployment}</span>
                  </div>
                </div>
              </a>

              {/* Content */}
              <div class="flex flex-col flex-grow p-5 gap-4">
                <div>
                  <h4 class="text-xl font-bold text-[var(--white)] mb-1.5 group-hover:text-[var(--sec)] transition-colors duration-300">
                    {project.title}
                  </h4>
                  <p class="text-[var(--white-icon)] text-sm leading-relaxed line-clamp-2">
                    {project.description}
                  </p>
                </div>

                {/* Tech icon stack with tooltips */}
                <div class="flex items-center gap-1.5">
                  {project.technologies.map((tech) => (
                    <div class="relative group/tech">
                      <div class="w-8 h-8 rounded-lg bg-[var(--white-icon-tr)] border border-[var(--white-icon-tr)] flex items-center justify-center hover:border-[var(--sec)]/40 hover:bg-[var(--sec)]/5 transition-all duration-200 cursor-default">
                        <img
                          src={tech.icon}
                          alt={tech.name}
                          class="w-4.5 h-4.5 object-contain opacity-75 group-hover/tech:opacity-100 transition-opacity"
                          width="18"
                          height="18"
                        />
                      </div>
                      {/* Tooltip */}
                      <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-2 py-1 text-[10px] font-medium text-[var(--white)] bg-[#0f1113] border border-[var(--white-icon-tr)] rounded-md whitespace-nowrap opacity-0 group-hover/tech:opacity-100 transition-opacity duration-150 pointer-events-none z-10">
                        {tech.name}
                        <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-[#0f1113]" />
                      </div>
                    </div>
                  ))}
                </div>

                {/* Divider */}
                <div class="h-px bg-gradient-to-r from-[var(--white-icon-tr)] via-[var(--white-icon-tr)] to-transparent" />

                {/* Action buttons */}
                <div class="flex gap-2 mt-auto">
                  <a
                    target="_blank"
                    href={project.link}
                    aria-label="GitHub Repository"
                    class="flex-1 flex justify-center items-center gap-2 py-2.5 px-3 rounded-xl border border-[var(--white-icon-tr)] text-[var(--white-icon)] hover:text-[var(--white)] hover:border-[var(--white-icon-tr)] hover:bg-[var(--white-icon-tr)] transition-all duration-200 group/btn text-sm font-medium"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 flex-shrink-0">
                      <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
                    </svg>
                    Code
                  </a>
                  {project.preview ? (
                    <a
                      target="_blank"
                      href={project.preview}
                      aria-label="Live Preview"
                      class="flex-1 flex justify-center items-center gap-2 py-2.5 px-3 rounded-xl bg-[var(--sec)]/10 border border-[var(--sec)]/30 text-[var(--sec)] hover:bg-[var(--sec)]/20 hover:border-[var(--sec)]/50 transition-all duration-200 text-sm font-semibold"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 flex-shrink-0">
                        <path d="M16.0037 9.41421L7.39712 18.0208L5.98291 16.6066L14.5895 8H7.00373V6H18.0037V17H16.0037V9.41421Z" />
                      </svg>
                      Live
                    </a>
                  ) : (
                    <span class="flex-1 flex justify-center items-center gap-2 py-2.5 px-3 rounded-xl border border-[var(--white-icon-tr)] text-[var(--white-icon)]/40 text-sm font-medium cursor-not-allowed select-none">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4 flex-shrink-0">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
                      </svg>
                      In Progress
                    </span>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
    

    <a
      target="_blank"
      href="https://github.com/Gan-dev?tab=repositories"
      aria-label="GitHub"
      class="group w-full flex items-center justify-center gap-2.5 mt-8 text-[var(--white-icon)] hover:text-[var(--white)] transition-all duration-300 border border-[var(--white-icon-tr)] hover:border-[var(--sec)]/30 p-3.5 rounded-2xl bg-[var(--component-bg)] hover:bg-[var(--sec)]/5"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5 group-hover:scale-110 transition-transform">
        <path d="M12.001 2C6.47598 2 2.00098 6.475 2.00098 12C2.00098 16.425 4.86348 20.1625 8.83848 21.4875C9.33848 21.575 9.52598 21.275 9.52598 21.0125C9.52598 20.775 9.51348 19.9875 9.51348 19.15C7.00098 19.6125 6.35098 18.5375 6.15098 17.975C6.03848 17.6875 5.55098 16.8 5.12598 16.5625C4.77598 16.375 4.27598 15.9125 5.11348 15.9C5.90098 15.8875 6.46348 16.625 6.65098 16.925C7.55098 18.4375 8.98848 18.0125 9.56348 17.75C9.65098 17.1 9.91348 16.6625 10.201 16.4125C7.97598 16.1625 5.65098 15.3 5.65098 11.475C5.65098 10.3875 6.03848 9.4875 6.67598 8.7875C6.57598 8.5375 6.22598 7.5125 6.77598 6.1375C6.77598 6.1375 7.61348 5.875 9.52598 7.1625C10.326 6.9375 11.176 6.825 12.026 6.825C12.876 6.825 13.726 6.9375 14.526 7.1625C16.4385 5.8625 17.276 6.1375 17.276 6.1375C17.826 7.5125 17.476 8.5375 17.376 8.7875C18.0135 9.4875 18.401 10.375 18.401 11.475C18.401 15.3125 16.0635 16.1625 13.8385 16.4125C14.201 16.725 14.5135 17.325 14.5135 18.2625C14.5135 19.6 14.501 20.675 14.501 21.0125C14.501 21.275 14.6885 21.5875 15.1885 21.4875C19.259 20.1133 21.9999 16.2963 22.001 12C22.001 6.475 17.526 2 12.001 2Z" />
      </svg>
      <span class="text-sm md:text-base font-medium">More on GitHub</span>
    </a>
 
  </div>
