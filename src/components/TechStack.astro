---
interface Tech {
  name: string;
  icon?: string;
}

interface Group {
  label: string;
  color: string;
  techs: Tech[];
}

const groups: Group[] = [
  {
    label: "Backend",
    color: "#37e4e7",
    techs: [
      { name: "NestJS", icon: "/svg/nestjs.svg" },
      { name: "Node.js", icon: "/svg/nodejs.svg" },
      { name: "TypeScript", icon: "/svg/typeScript.svg" },
      { name: "Python", icon: "/svg/Python.svg" },
      { name: "RabbitMQ" },
      { name: "DDD / Hexagonal" },
    ],
  },
  {
    label: "Databases & Data",
    color: "#a78bfa",
    techs: [
      { name: "PostgreSQL", icon: "/svg/postgresql.svg" },
      { name: "MySQL", icon: "/svg/mysql.svg" },
      { name: "MongoDB", icon: "/svg/MongoDB.svg" },
      { name: "Snowflake" },
      { name: "Metabase" },
      { name: "Redis" },
    ],
  },
  {
    label: "DevOps & Cloud",
    color: "#34d399",
    techs: [
      { name: "Docker", icon: "/svg/docker.svg" },
      { name: "Git", icon: "/svg/git.svg" },
      { name: "AWS EC2 / RDS", icon: "/svg/aws-cloud.svg" },
      { name: "Linux / Bash", icon: "/svg/bash.svg" },
      { name: "CI/CD" },
      { name: "Vercel", icon: "/svg/vercel.svg" },
    ],
  },
  {
    label: "AI & Automation",
    color: "#f59e0b",
    techs: [
      { name: "n8n", icon: "/svg/n8n.svg" },
      { name: "AI Agents", icon: "/svg/ai-agent.svg" },
      { name: "LLM / MCP" },
      { name: "LangChain" },
      { name: "WhatsApp API" },
    ],
  },
];
---

<div class="space-y-3">
  {
    groups.map((group) => (
      <div class="p-4 rounded-2xl bg-[var(--component-bg)] border border-[var(--component-border)] hover:border-[var(--sec)]/20 transition-colors duration-300">
        <p
          class="text-xs font-semibold uppercase tracking-wider mb-3"
          style={`color: ${group.color}`}
        >
          {group.label}
        </p>
        <div class="flex flex-wrap gap-2">
          {group.techs.map((tech) => (
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium text-[var(--white-muted)] bg-[var(--white-icon-tr)] border border-[var(--component-border)] hover:text-[var(--white)] transition-colors duration-200">
              {tech.icon && (
                <img
                  src={tech.icon}
                  alt={tech.name}
                  class="w-3.5 h-3.5 object-contain opacity-80"
                  width="14"
                  height="14"
                  loading="lazy"
                />
              )}
              {tech.name}
            </span>
          ))}
        </div>
      </div>
    ))
  }
</div>
